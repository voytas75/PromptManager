# Copy this file to `.env` for local development.
# `.env` is git-ignored; keep real secrets there or in host-level secret stores.

# Core local paths
PROMPT_MANAGER_CONFIG_JSON=config/config.json
PROMPT_MANAGER_DATABASE_PATH=data/prompt_manager.db
PROMPT_MANAGER_CHROMA_PATH=data/chromadb

# Optional caching
# PROMPT_MANAGER_REDIS_DSN=redis://localhost:6379/0
PROMPT_MANAGER_CACHE_TTL_SECONDS=300

# Minimal offline-friendly setup
PROMPT_MANAGER_EMBEDDING_BACKEND=deterministic
PROMPT_MANAGER_WEB_SEARCH_PROVIDER=

# Optional LiteLLM execution
# PROMPT_MANAGER_LITELLM_MODEL=gpt-4o-mini
# PROMPT_MANAGER_LITELLM_INFERENCE_MODEL=gpt-4.1
# PROMPT_MANAGER_LITELLM_API_KEY=sk-...
# PROMPT_MANAGER_LITELLM_API_BASE=https://your-endpoint.example.com
# PROMPT_MANAGER_LITELLM_API_VERSION=2025-04-01-preview
PROMPT_MANAGER_LITELLM_STREAM=false
PROMPT_MANAGER_LITELLM_LOGGING=false

# Optional voice playback
# PROMPT_MANAGER_LITELLM_TTS_MODEL=openai/tts-1
PROMPT_MANAGER_LITELLM_TTS_STREAM=true

# Optional web search providers
# PROMPT_MANAGER_WEB_SEARCH_PROVIDER=tavily
# PROMPT_MANAGER_EXA_API_KEY=exa_...
# PROMPT_MANAGER_TAVILY_API_KEY=tvly-...
# PROMPT_MANAGER_SERPER_API_KEY=serper-...
# PROMPT_MANAGER_SERPAPI_API_KEY=serpapi-...
# PROMPT_MANAGER_GOOGLE_API_KEY=AIza...
# PROMPT_MANAGER_GOOGLE_CSE_ID=your-cse-id

# Optional sharing
PROMPT_MANAGER_AUTO_OPEN_SHARE_LINKS=true
# PROMPT_MANAGER_PRIVATEBIN_URL=https://privatebin.net/
# PROMPT_MANAGER_PRIVATEBIN_EXPIRATION=1week
# PROMPT_MANAGER_PRIVATEBIN_FORMAT=markdown
# PROMPT_MANAGER_PRIVATEBIN_COMPRESSION=zlib
# PROMPT_MANAGER_PRIVATEBIN_BURN_AFTER_READING=false
# PROMPT_MANAGER_PRIVATEBIN_OPEN_DISCUSSION=false

# Optional UI customization
PROMPT_MANAGER_PROMPT_OUTPUT_FONT_FAMILY=JetBrains Mono
PROMPT_MANAGER_PROMPT_OUTPUT_FONT_SIZE=13
PROMPT_MANAGER_PROMPT_OUTPUT_FONT_COLOR=#B5CFED
PROMPT_MANAGER_CHAT_FONT_FAMILY=Segoe UI
PROMPT_MANAGER_CHAT_FONT_SIZE=12
PROMPT_MANAGER_CHAT_FONT_COLOR=#B5CFED
